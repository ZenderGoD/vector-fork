# -----------------------------------------------------------------------------
# AIKP — Sample Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (ignored by git) and tweak values as needed.
# -----------------------------------------------------------------------------

# -------------------------
# Core Application Settings
# -------------------------
BETTER_AUTH_SECRET=replace_me_with_a_secure_random_string
APP_URL=http://localhost:3000
# Optional override for Better Auth callbacks (falls back to APP_URL if unset)
BETTER_AUTH_URL=http://localhost:3000

# -----------------
# Database (Postgres)
# -----------------
# These match the defaults in `docker-compose.dev.yml`.
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass
POSTGRES_DB=devdb
DATABASE_URL=postgresql://devuser:devpass@localhost:5432/devdb

# -------------
# SMTP (Optional)
# -------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
SMTP_FROM="AIKP <aikp@example.com>"

# -------------------------
# AWS S3 / MinIO (File Uploads)
# -------------------------
# The defaults point to the local MinIO instance defined in `docker-compose.dev.yml`.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=aikp-local
# When using MinIO or any S3-compatible local storage, keep these values:
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# If you expose uploaded files via a custom domain, set this (optional):
# S3_PUBLIC_BASE_URL=https://files.example.com 